# Copy this file to .env for local runs

# Docker/PostgreSQL container variables
POSTGRES_DB=nutri_ledger
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Spring datasource variables
DB_URL=jdbc:postgresql://localhost:5432/nutri_ledger
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Spring Redis/cache variables
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
