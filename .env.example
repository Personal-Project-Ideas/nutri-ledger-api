ENV=
APP_NAME=
SPRING_PROFILES_ACTIVE=
SERVER_PORT=
SERVER_CONTEXT_PATH=

MONGO_INITDB_ROOT_PASSWORD=
MONGO_INITDB_ROOT_USERNAME=
MONGO_DB_NAME=

POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=

LOG_DEBUG_ENABLED=

DB_POOL_NAME=
DB_POOL_MIN_IDLE=
DB_POOL_MAX_SIZE=
DB_POOL_IDLE_TIMEOUT_MS=
DB_POOL_MAX_LIFETIME_MS=
DB_POOL_CONNECTION_TIMEOUT_MS=

JPA_DDL_AUTO_LOCAL=
JPA_SHOW_SQL_LOCAL=
JPA_FORMAT_SQL_LOCAL=

JPA_DDL_AUTO_PROD=
JPA_SHOW_SQL_PROD=
JPA_FORMAT_SQL_PROD=

# Test profile (mvn test): in-memory H2; JPA create-drop from entities in application-test.yaml.
# Set SPRING_PROFILES_ACTIVE=test when running tests, or rely on @ActiveProfiles("test") in tests.
TEST_DB_URL=jdbc:h2:mem:nutri_ledger_test;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
TEST_DB_USERNAME=sa
TEST_DB_PASSWORD=
TEST_CACHE_TYPE=none

GOOGLE_PEOPLE_API_URL=

REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=


GCLOUD_PROJECT=
GCLOUD_CLIENT_ID=
# Use v2 auth endpoint (not legacy /oauth2/auth).
GCLOUD_AUTH_URI=https://accounts.google.com/o/oauth2/v2/auth
GCLOUD_TOKEN_URI=https://oauth2.googleapis.com/token
GCLOUD_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCLOUD_CLIENT_SECRET=
# Must match Google Console → Credentials → OAuth client → Authorized redirect URIs (exact string).
# Built from SERVER_PORT + SERVER_CONTEXT_PATH below; no trailing slash.
OAUTH2_REDIRECT_URI=http://localhost:8080/nutri-ledger/api/login/oauth2/code/google
APP_AUTH_COOKIE_SECURE=
APP_CORS_ALLOWED_ORIGINS=